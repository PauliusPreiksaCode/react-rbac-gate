{
  "name": "react-rbac-gate",
  "version": "0.1.1",
  "description": "Lightweight, flexible role-based access control for React. Supports role hierarchy, permissions, custom rules, and debug mode.",
  "keywords": [
    "react",
    "rbac",
    "role-based-access-control",
    "permissions",
    "authorization",
    "access-control"
  ],
  "author": "Paulius Preikša",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PauliusPreiksaCode/react-rbac-gate.git"
  },
  "homepage": "https://github.com/PauliusPreiksaCode/react-rbac-gate#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./hoc": {
      "import": "./dist/hoc.js",
      "require": "./dist/hoc.cjs",
      "types": "./dist/hoc.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "example": "cd example && vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "docs": "typedoc",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typedoc": "^0.27.9",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.2.0"
  }
}
